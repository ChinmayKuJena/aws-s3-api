<div class="card">
    <div class="card-header">
        <div>
            <h3 class="card-title">All Buckets</h3>
            <p class="card-subtitle">S3 buckets in your AWS account</p>
        </div>
        <button class="btn btn-primary" onclick="loadBuckets()" id="refresh-buckets-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;">
                <polyline points="23 4 23 10 17 10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            Refresh
        </button>
    </div>
    <div class="card-body">
        <div class="loading" id="loading">
            <div class="spinner"></div>
            <p class="loading-text">Loading buckets...</p>
        </div>
        
        <div id="buckets-container" class="bucket-grid" style="display: none;"></div>
        
        <div id="empty-state" class="empty-state" style="display: none;">
            <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
            <h3 class="empty-state-title">No buckets found</h3>
            <p class="empty-state-text">Create a bucket in your AWS account to get started.</p>
        </div>
        
        <div id="error" class="result-box result-error"></div>
    </div>
</div>

<script>
    async function loadBuckets() {
        const loading = document.getElementById('loading');
        const container = document.getElementById('buckets-container');
        const emptyState = document.getElementById('empty-state');
        const error = document.getElementById('error');
        
        loading.classList.add('show');
        container.style.display = 'none';
        emptyState.style.display = 'none';
        error.classList.remove('show');
        
        try {
            const response = await fetch('/api/v1/s3/buckets');
            const data = await response.json();
            
            loading.classList.remove('show');
            
            if (data.success && data.data && data.data.length > 0) {
                container.innerHTML = '';
                
                data.data.forEach((bucket, index) => {
                    const card = document.createElement('div');
                    card.className = 'bucket-card';
                    card.style.animation = `fadeIn 0.4s ease ${index * 0.06}s both`;
                    card.innerHTML = `
                        <div class="bucket-card-header">
                            <div class="bucket-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                                </svg>
                            </div>
                        </div>
                        <div class="bucket-name">${bucket.Name}</div>
                        <div class="bucket-meta">Created: ${new Date(bucket.CreationDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
                        <div style="margin-top: 14px; display: flex; gap: 8px;">
                            <a href="/objects?bucket=${encodeURIComponent(bucket.Name)}" class="btn btn-secondary btn-sm">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                                Browse
                            </a>
                            <a href="/upload?bucket=${encodeURIComponent(bucket.Name)}" class="btn btn-primary btn-sm">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                    <polyline points="17 8 12 3 7 8"/>
                                    <line x1="12" y1="3" x2="12" y2="15"/>
                                </svg>
                                Upload
                            </a>
                        </div>
                    `;
                    container.appendChild(card);
                });
                
                container.style.display = 'grid';
            } else if (data.success) {
                emptyState.style.display = 'block';
            } else {
                throw new Error(data.message || 'Failed to load buckets');
            }
        } catch (err) {
            loading.classList.remove('show');
            error.textContent = 'Error: ' + err.message;
            error.classList.add('show');
        }
    }

    document.addEventListener('DOMContentLoaded', loadBuckets);
</script>
